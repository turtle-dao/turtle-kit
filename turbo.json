{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", "tsconfig.base.json"],
  "tasks": {
    "codegen": {
      "inputs": ["openapi-ts.config.ts", "hey-api.runtime.ts", "specs/openapi.v2.json"],
      "outputs": ["src/client/**"]
    },
    "build": {
      "dependsOn": ["^build", "codegen"],
      "outputs": ["dist/**"]
    },
    "type-check": {
      "dependsOn": ["^build", "codegen"]
    },
    "clean": {
      "cache": false
    }
  }
}
