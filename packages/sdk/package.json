{
  "name": "@turtleclub/sdk",
  "version": "0.0.0",
  "type": "module",
  "description": "TypeScript SDK for the Turtle Earn v2 API, autogenerated from the OpenAPI spec",
  "author": {
    "name": "Turtle",
    "url": "https://www.turtle.xyz"
  },
  "license": "MIT",
  "homepage": "https://www.turtle.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/turtle-dao/turtle-kit.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/turtle-dao/turtle-kit/issues"
  },
  "keywords": [
    "turtle",
    "sdk",
    "openapi",
    "earn",
    "defi"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "codegen": "openapi-ts",
    "build": "bun run codegen && tsup",
    "type-check": "bun run codegen && tsc --noEmit",
    "clean": "rm -rf dist src/client",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.97.1",
    "tsup": "^8.3.0",
    "typescript": "^5.9.2"
  }
}
