    "/v2/opportunities/{chainId}/{vaultAddress}/historical": {
      "get": {
        "tags": [
          "Historical Data"
        ],
        "summary": "Get Vault Historical Data",
        "description": "Get combined historical time-series (TVL, share price, base APY) for a vault, bucketed by interval over [from, to].",
        "operationId": "GetOpportunityHistorical",
        "parameters": [
          {
            "name": "intervalSeconds",
            "in": "query",
            "description": "Bucket width in seconds. Defaults to 86400 (1 day)",
            "schema": {
              "default": 86400,
              "description": "Bucket width in seconds. Defaults to 86400 (1 day)",
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "name": "fromTimestamp",
            "in": "query",
            "description": "Unix seconds, inclusive. Defaults to now - 30d when omitted",
            "schema": {
              "description": "Unix seconds, inclusive. Defaults to now - 30d when omitted",
              "type": "integer"
            }
          },
          {
            "name": "toTimestamp",
            "in": "query",
            "description": "Unix seconds, inclusive. Defaults to now when omitted",
            "schema": {
              "description": "Unix seconds, inclusive. Defaults to now when omitted",
              "type": "integer"
            }
          },
          {
            "name": "chainId",
            "in": "path",
            "description": "EVM chain ID (e.g. 1 for Ethereum)",
            "required": true,
            "schema": {
              "description": "EVM chain ID (e.g. 1 for Ethereum)",
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "name": "vaultAddress",
            "in": "path",
            "description": "0x-prefixed 40-hex vault contract address",
            "required": true,
            "schema": {
              "description": "0x-prefixed 40-hex vault contract address",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V2GetOpportunityHistoricalResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RestErrResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RestErrResponse"
                }
              }
            }
          }
        }
      }
    },
