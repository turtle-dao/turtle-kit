{
  "name": "turtle-kit",
  "version": "0.0.0",
  "private": true,
  "description": "Turtle developer kit — SDK, MCP server, and Claude Code skills for the Turtle Earn API",
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "type-check": "turbo run type-check",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "codegen": "turbo run codegen",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "turbo": "2.9.6",
    "typescript": "^5.9.2"
  }
}
